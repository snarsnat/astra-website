# GitHub OAuth Configuration
# Register your OAuth app at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_CALLBACK_URL=http://localhost:8080/api/auth/github/callback

# Session Secret (generate a random string)
SESSION_SECRET=generate_a_random_secret_string_here

# Server Configuration
PORT=8080
HOST=localhost

# Database Configuration
DB_PATH=astra_auth.db

# Development/Production Mode
NODE_ENV=development

# GitHub API Rate Limiting (optional)
GITHUB_RATE_LIMIT_REQUESTS=5000
GITHUB_RATE_LIMIT_PERIOD=3600

# How to generate a session secret:
# python3 -c "import secrets; print(secrets.token_hex(32))"